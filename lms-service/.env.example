# ==========================================
# Go LMS Service Local Configuration
# ==========================================
APP_ENV=development
APP_PORT=8081
APP_NAME="LMS Service"

# Database Configuration (Chỉ cần cho LMS DB)
DB_HOST=localhost
DB_PORT=5432
DB_USER=lms_user
DB_PASSWORD=your_local_postgres_password
DB_NAME=lms_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_local_redis_password

# MinIO Object Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_admin_password
MINIO_BUCKET=lms-files
STORAGE_TYPE=minio

# JWT (Phải khớp với auth-service)
JWT_SECRET=your_jwt_secret_key_must_be_long_at_least_32_characters

# Kafka Brokers
KAFKA_BROKERS=localhost:9092

# Sync secret (Phải khớp với LMS_API_SECRET bên Auth)
LMS_SYNC_SECRET=lms-sync-secret-change-me

# Các API URL tích hợp
AUTH_SERVICE_URL=http://localhost:8080
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_SECRET=ai-service-secret-change-me

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
