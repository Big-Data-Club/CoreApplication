# ==========================================
# Auth & Management Service Local Configuration
# ==========================================
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=local

# Database Configuration (Chỉ cần cho Auth DB)
DB_PASSWORD=your_local_postgres_password

# JWT (Phải khớp với lms-service)
JWT_SECRET=your_jwt_secret_key_must_be_long_at_least_32_characters
JWT_EXPIRATION_MS=3600000

# Email (SMTP Gmail)
EMAIL=your_email@gmail.com
EMAIL_PASSWORD=your_app_password

# Google OAuth2.0
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# URL và Secret của các Service khác
LMS_API_URL=http://localhost:8081
LMS_API_SECRET=lms-sync-secret-change-me

AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_SECRET=ai-service-secret-change-me

CHAT_API_URL=http://localhost:8082
CHAT_SYNC_SECRET=chat-sync-secret-change-me

# Kafka Bootstrap Server
KAFKA_BROKERS=localhost:9092

# General Settings
APP_PUBLIC_URL=http://localhost:3000
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=admin_generated_password
