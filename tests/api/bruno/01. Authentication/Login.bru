meta {
  name: Login Admin
  type: http
  seq: 1
}

post {
  url: {{AUTH_URL}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "{{admin_email}}",
    "password": "{{admin_password}}"
  }
}

script:post-response {
  if (res.status === 200 && res.body.token) {
    bru.setVar("token", res.body.token);
    console.log("Token successfully stored in environment variables!");
  }
}
