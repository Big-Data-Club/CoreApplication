meta {
  name: Update Member Role
  type: http
  seq: 2
}

put {
  url: {{LMS_URL}}/lmsapiv1/api/v1/admin/organizations/{{created_org_id}}/members/{{test_user_id}}/role
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  Content-Type: application/json
}

body:json {
  {
    "org_role": "ADMIN"
  }
}
