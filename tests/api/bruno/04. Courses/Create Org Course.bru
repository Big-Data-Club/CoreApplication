meta {
  name: Create Org Course
  type: http
  seq: 1
}

post {
  url: {{LMS_URL}}/lmsapiv1/api/v1/courses
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{token}}
  Content-Type: application/json
}

body:json {
  {
    "title": "Organization Specific Course",
    "description": "This course is restricted to organization members.",
    "category": "Computer Science",
    "level": "INTERMEDIATE",
    "org_id": {{created_org_id}},
    "visibility": "ORG_ONLY"
  }
}

script:post-response {
  if (res.status === 201 && res.body.data && res.body.data.id) {
    bru.setVar("created_course_id", res.body.data.id);
    console.log("Created Course ID stored: " + res.body.data.id);
  }
}
