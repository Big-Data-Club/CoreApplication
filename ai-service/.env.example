# ==========================================
# FastAPI AI Service Local Configuration
# ==========================================
APP_ENV=development
LOG_LEVEL=INFO

# Database Configuration (Chỉ cần cho AI DB)
AI_DB_HOST=localhost
AI_DB_PORT=5432
AI_DB_USER=ai_user
AI_DB_PASSWORD=your_local_postgres_password
AI_DB_NAME=ai_db

# Qdrant Vector Store
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_PREFER_GRPC=true

# Neo4j Graph Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_local_neo4j_password

# Redis (Dùng cho cache status công việc)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_local_redis_password

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_admin_password
MINIO_BUCKET=lms-files

# LLM & Embedding models
GROQ_API_KEY=gsk_your_groq_api_key
CHAT_MODEL=llama-3.1-8b-instant
QUIZ_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=BAAI/bge-m3

# Internal security
AI_SERVICE_SECRET=ai-service-secret-change-me
LMS_SERVICE_URL=http://localhost:8081
