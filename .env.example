# ================================
# Environment Configuration
# ================================

# ================================
# Application Settings
# ================================
SPRING_PROFILES_ACTIVE=docker
VERSION=1.0.0

# ================================
# Ports
# ================================
BACKEND_PORT=8080
POSTGRES_PORT=5433
LMS_POSTGRES_PORT=5434
AI_POSTGRES_PORT=5435
LAB_POSTGRES_PORT=5436
LAB_PORT=8082

# ================================
# Auth Database
# ================================
POSTGRES_DB=<TODO>              # [REQUIRED]
POSTGRES_USER=<TODO>            # [REQUIRED]
POSTGRES_PASSWORD=<TODO>        # [REQUIRED] [GENERATED]

# ================================
# Auth Admin Bootstrap
# ================================
ADMIN_EMAIL=<TODO>              # [REQUIRED] e.g. admin@yourdomain.com
ADMIN_PASSWORD=<TODO>           # [REQUIRED] [GENERATED] Change after first login

# ================================
# LMS Database
# ================================
LMS_POSTGRES_DB=<TODO>          # [REQUIRED]
LMS_POSTGRES_USER=<TODO>        # [REQUIRED]
LMS_POSTGRES_PASSWORD=<TODO>    # [REQUIRED] [GENERATED]

# ================================
# Lab Database
# ================================
LAB_POSTGRES_DB=lab_db          # [DEFAULT OK]
LAB_POSTGRES_USER=lab_user      # [DEFAULT OK]
LAB_POSTGRES_PASSWORD=<TODO>    # [REQUIRED] [GENERATED]

# ================================
# AI Database
# ================================
AI_POSTGRES_DB=ai_db            # [DEFAULT OK]
AI_POSTGRES_USER=ai_user        # [DEFAULT OK]
AI_POSTGRES_PASSWORD=<TODO>     # [REQUIRED] [GENERATED]

# ================================
# HikariCP Connection Pool
# ================================
HIKARI_MAX_POOL_SIZE=10
HIKARI_MIN_IDLE=5
HIKARI_CONNECTION_TIMEOUT=30000
HIKARI_IDLE_TIMEOUT=600000
HIKARI_MAX_LIFETIME=1800000

# ================================
# JPA/Hibernate Settings
# ================================
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# ================================
# JWT Security
# ================================
# [REQUIRED] [GENERATED] Must be identical in backend AND lms-service. Min 32 chars.
JWT_SECRET=<TODO>
JWT_EXPIRATION_MS=3600000

# ================================
# Logging
# ================================
LOG_LEVEL=INFO

# ================================
# JVM Options
# ================================
JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0 -XX:+UseG1GC

# ================================
# MinIO Object Storage
# ================================
MINIO_ROOT_USER=<TODO>          # [REQUIRED]
MINIO_ROOT_PASSWORD=<TODO>      # [REQUIRED] [GENERATED]

# ================================
# Redis
# ================================
REDIS_PASSWORD=<TODO>           # [REQUIRED] [GENERATED]
REDIS_PORT=6379

REDIS_POOL_SIZE=50              # max sockets per LMS replica
REDIS_MIN_IDLE_CONNS=10         # warm pool to absorb traffic spikes
REDIS_DIAL_TIMEOUT=3s
REDIS_READ_TIMEOUT=500ms        # fail fast and fall back to DB on Redis hiccups
REDIS_WRITE_TIMEOUT=500ms
REDIS_POOL_TIMEOUT=1s

DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m

# ================================
# LMS Service (Go)
# ================================
APP_ENV=production
LMS_PORT=8081
CORS_ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:3000

# ================================
# Lab Service (Go)
# ================================
LAB_PORT=8082

EMAIL_PASSWORD=<TODO>           # [REQUIRED] Gmail App Password (16 chars, not regular password)
EMAIL=<TODO>                    # [REQUIRED] Gmail address
APP_PUBLIC_URL=<TODO>           # [REQUIRED] e.g. https://bdc.hpcc.vn

NEXTAUTH_URL=<TODO>             # [REQUIRED] Must match production domain
NEXTAUTH_SECRET=<TODO>          # [REQUIRED] [GENERATED] Min 32 chars
GOOGLE_SCRIPT_URL=<TODO>        # Google Apps Script URL for survey forms

BACKEND_URL=http://backend:8080 # [DEFAULT OK] Docker internal
LMS_API_URL=http://lms-backend:8081  # [DEFAULT OK] Docker internal
AI_SERVICE_URL=http://ai-service:8000  # [DEFAULT OK] Docker internal

# [REQUIRED] Secret for lms-service sync endpoint. Must match LMS_SYNC_SECRET.
LMS_API_SECRET=<TODO>           # [GENERATED]
LMS_SYNC_SECRET=<TODO>          # [GENERATED] Must equal LMS_API_SECRET

# ================================
# YouTube Integration
# ================================
YOUTUBE_CLIENT_ID=<TODO>
YOUTUBE_CLIENT_SECRET=<TODO>
YOUTUBE_REDIRECT_URL=<TODO>
YOUTUBE_REDIRECT_URI=<TODO>
NEXT_PUBLIC_YOUTUBE_UPLOAD_ENABLED=true

# ================================
# AI Service
# ================================
AI_SERVICE_SECRET=<TODO>

GROQ_API_KEY=<TODO>
AI_CHAT_MODEL=llama-3.1-8b-instant     # Default chat model (used as initial seed binding)
AI_QUIZ_MODEL=llama-3.3-70b-versatile  # Default quiz/high-reasoning model

AI_KEY_ENCRYPTION_SECRET=<TODO>
LLM_BOOTSTRAP_ON_STARTUP=true

EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024
EMBEDDING_PREFIX_MODE=bge
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
REINDEX_BATCH_SIZE=5
RERANK_FETCH_K=15

STORAGE_TYPE=minio              # 'local' for dev, 'minio' for production

# ================================
# Neo4j Knowledge Graph
# ================================
# [REQUIRED] [GENERATED] Change from default before production deploy.
NEO4J_PASSWORD=<TODO>

# ================================
# Docker Registry
# ================================
DOCKER_USERNAME=<TODO>
DOCKER_PASSWORD=<TODO>
IMAGE_TAG=latest

# ================================
# Auth Database (Neon)
# ================================
POSTGRES_HOST=<TODO>
POSTGRES_DB=auth
POSTGRES_USER=<TODO>
POSTGRES_PASSWORD=<TODO>

# ================================
# LMS Database (Neon)
# ================================
LMS_POSTGRES_HOST=<TODO>
LMS_POSTGRES_DB=lms
LMS_POSTGRES_USER=<TODO>
LMS_POSTGRES_PASSWORD=<TODO>

# ================================
# AI Database (Neon)
# ================================
AI_POSTGRES_HOST=<TODO>
AI_POSTGRES_DB=ai
AI_POSTGRES_USER=<TODO>
AI_POSTGRES_PASSWORD=<TODO>

# ================================
# Qdrant Serverless
# ================================
QDRANT_API_KEY=<TODO>
QDRANT_URL=<TODO>

# ================================
# Neo4J Serverless
