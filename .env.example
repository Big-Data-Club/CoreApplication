AI_DB_SSL=require

# ================================
# Storage (Cloudflare R2)
# ================================
MINIO_ROOT_USER=<TODO>
MINIO_ROOT_PASSWORD=<TODO>
R2_ENDPOINT=<TODO>

# ================================
# Storage (Cloudflare R2 for Lab Service)
# ================================
LAB_MINIO_ROOT_USER=<TODO>
LAB_MINIO_ROOT_PASSWORD=<TODO>
LAB_R2_ENDPOINT=<TODO>
LAB_MINIO_BUCKET=lab-files
LAB_MINIO_USE_SSL=true

# ================================
# Lab Database (Neon)
# ================================
LAB_POSTGRES_HOST=<TODO>
LAB_POSTGRES_DB=lab
LAB_POSTGRES_USER=<TODO>
LAB_POSTGRES_PASSWORD=<TODO>

# ================================
# Chat Service (Go)
# ================================
CHAT_PORT=8083

# Chat Database (Neon)
CHAT_POSTGRES_HOST=<TODO>
CHAT_POSTGRES_DB=chat
CHAT_POSTGRES_USER=<TODO>
CHAT_POSTGRES_PASSWORD=<TODO>
CHAT_DB_SSL_MODE=require

# Shared sync secret (auth-service → chat-service)
CHAT_SYNC_SECRET=<TODO>

# WebSocket URL for frontend client
# Dev: ws://localhost:8083/api/v1   Production: wss://bdc.hpcc.vn/chatapiv1
NEXT_PUBLIC_CHAT_WS_URL=ws://localhost:8083/api/v1

# Chat API URL (server-side Next.js proxy target)
CHAT_API_URL=http://chat-backend:8083

# ================================
# LaTeX Service (BDCTex)
# ================================
LATEX_PORT=8084
LATEX_DB_PORT=5437
LATEX_WORKER_COUNT=8
LATEX_MAX_TIMEOUT=120
LATEX_MAX_MEMORY_MB=512
LATEX_MINIO_BUCKET=latex-files

# Local Docker Database
LATEX_DB_HOST=postgres-latex
LATEX_DB_USER=latexuser
LATEX_DB_PASSWORD=latexpass
LATEX_DB_NAME=latexdb

# Serverless Neon Database (Production)
# LATEX_DB_HOST=ep-xxxxx.ap-southeast-1.aws.neon.tech
# LATEX_DB_USER=latexdb_owner
# LATEX_DB_PASSWORD=neon_password_here
# LATEX_DB_NAME=latexdb
# LATEX_DB_SSLMODE=require

# Next.js Server-side Proxy Target
LATEX_API_URL=http://latex-backend:8084

