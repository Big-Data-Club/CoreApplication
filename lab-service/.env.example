# ==========================================
# Lab Service Local Configuration
# ==========================================
APP_NAME="Lab Service"
APP_ENV=development
APP_PORT=8082
VERSION=1.0.0

# Database Configuration (Chỉ cần cho Lab DB)
DB_HOST=localhost
DB_PORT=5436
DB_USER=lab_user
DB_PASSWORD=your_local_postgres_password
DB_NAME=lab_db
DB_SSL_MODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_local_redis_password
REDIS_DB=2

# JWT (Phải khớp với auth-service)
JWT_SECRET=your_jwt_secret_key_must_be_long_at_least_32_characters

# MinIO Storage
STORAGE_TYPE=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_admin_password
MINIO_BUCKET=lab-files

# Kubernetes Cluster Config (if applicable for sandbox execution)
K8S_IN_CLUSTER=false
K8S_NAMESPACE=lab-sessions
K8S_DEFAULT_IMAGE=ubuntu:22.04

# Kafka Bootstrap Server
KAFKA_BROKERS=localhost:9092
LMS_SYNC_SECRET=lms-sync-secret-change-me
